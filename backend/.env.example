APP_NAME=askk-prototype
APP_ENV=dev
DEBUG=true

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Security ---
SECRET_KEY=change-me-in-prod-very-long-random-string-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=14

# --- Database ---
# В проде: postgresql+asyncpg://user:pass@host:5432/db
# Для TimescaleDB hypertable нужен PostgreSQL 12+ (TimescaleDB extension)
DATABASE_URL=postgresql+asyncpg://askk:askk@localhost:5432/askk
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- MinIO (S3-совместимое хранилище фото) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=askk-photos
MINIO_SECURE=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- АСУ ТП (пока мок) ---
ASUTP_MODE=mock
ASUTP_MOCK_INTERVAL_SEC=60

# --- Геолокация (допустимый радиус, метров) ---
GEO_RADIUS_M=75
