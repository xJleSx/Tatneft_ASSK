"""CV-сервис — переменные окружения. Скопируйте в .env и подправьте."""

# Режим: dev / staging / prod
APP_ENV=dev

# Какой детектор использовать:
#   coco    — YOLOv8n pretrained на COCO (placeholder для MVP)
#   defect  — заглушка под обученную модель дефектов
#   mock    — для локальных тестов без torch
DETECTOR=coco

# Путь к .pt файлу (если свой). Пусто -> yolov8n.pt из коробки ultralytics.
# MODEL_PATH=/models/defect_yolov8n_v1.pt

# Устройство: cpu / cuda:0 / mps
DEVICE=cpu

# Пороги детекции
CONFIDENCE=0.25
IOU=0.45

# Лимит размера загружаемого изображения (байт)
MAX_IMAGE_BYTES=15728640

# Таймаут инференса, мс
INFERENCE_TIMEOUT_MS=30000
