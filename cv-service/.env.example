# CV-сервис — переменные окружения. Скопируйте в .env и подправьте.
#
# APP_ENV=dev|staging|prod
# DETECTOR=defect
# DEVICE=cpu|cuda:0|mps
# DEFECT_CONFIDENCE=0.25
# DEFECT_IOU=0.45
# MAX_IMAGE_BYTES=15728640

# Режим: dev / staging / prod
APP_ENV=dev

# Детектор: только `defect` (YOLOv8, 3 класса дефектов: corrosion / leak / damage)
DETECTOR=defect

# Устройство: cpu / cuda:0 / mps
DEVICE=cpu

# Пороги детекции для дефектов
DEFECT_CONFIDENCE=0.25
DEFECT_IOU=0.45

# Лимит размера загружаемого изображения (байт)
MAX_IMAGE_BYTES=15728640
